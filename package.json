{
  "name": "gas-pomodoro",
  "version": "1.0.0",
  "description": "Pomodoro Timer powered by Google Apps Script + Spreadsheet",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vite build",
    "build:gas": "vite build && tsx scripts/build-gas.ts",
    "deploy": "pnpm run build:gas && clasp push",
    "push": "clasp push",
    "open": "clasp open --webapp",
    "login": "clasp login",
    "typecheck": "tsc --noEmit -p tsconfig.client.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"client/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"client/**/*.{ts,tsx}\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "optionalDependencies": {
    "tiptap-markdown-editor": "link:../tiptap-markdown-editor"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@eslint/js": "^9.39.2",
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.83",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "esbuild": "^0.27.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.3.5"
  }
}
