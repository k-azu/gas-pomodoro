{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./client/*"]
    },
    "baseUrl": "."
  },
  "include": ["client/**/*.ts", "client/**/*.tsx", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
